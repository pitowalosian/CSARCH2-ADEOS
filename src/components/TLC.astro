---
// TLC.astro
import "../styles/interactables.css";

const charges = Array.from({ length: 7 });
const cells = [
  { gate: "w1", store: "r", bank: "l", display: "d1", label: "Control Gate (MS)", chargeClass: "c" },
  { gate: "w2", store: "r2", bank: "l2", display: "d2", label: "Control Gate", chargeClass: "c2" },
  { gate: "w3", store: "r3", bank: "l3", display: "d3", label: "Control Gate", chargeClass: "c3" },
  { gate: "w4", store: "r4", bank: "l4", display: "d4", label: "Control Gate (LS)", chargeClass: "c4" },
];
---

<section class="flash-demo flash-demo--tlc" aria-label="Triple-Level Cell demo">
  <div class="flash-demo__cells">
    {cells.map((cell) => (
      <article class="flash-demo__cell">
        <button id={cell.gate} class="flash-demo__layer flash-demo__gate" type="button">{cell.label}</button>
        <div class="flash-demo__layer flash-demo__oxide">Isolation Layer</div>
        <div class="flash-demo__layer flash-demo__floating">
          Floating Gate
          <div id={cell.store} class="flash-demo__charge-well"></div>
        </div>
        <div class="flash-demo__layer flash-demo__oxide">Isolation Layer</div>
        <div class="flash-demo__layer flash-demo__substrate">
          Substrate
          <div id={cell.bank} class="flash-demo__charge-bank">
            {charges.map((_, i) => (
              <div class={`flash-demo__charge flash-demo__charge--tlc ${cell.chargeClass}`} data-id={i}></div>
            ))}
          </div>
        </div>
      </article>
    ))}
  </div>

  <aside class="flash-demo__panel">
    <p>Click a control gate to move one charge marker into the floating gate.</p>
    <p>Each TLC cell represents 3 bits, so each cell can step through eight possible states.</p>

    <div class="flash-demo__display" aria-label="Current TLC stored values">
      {cells.map((cell) => (
        <div class="flash-demo__value">
          <span>{cell.label.replace("Control Gate ", "")}</span>
          <strong id={cell.display}></strong>
        </div>
      ))}
      <div class="flash-demo__value flash-demo__value--wide">
        <span>Total bits</span>
        <strong id="d5"></strong>
      </div>
      <div class="flash-demo__value">
        <span>Hex</span>
        <strong id="d6"></strong>
      </div>
    </div>

    <button class="flash-demo__erase" id="erase" type="button">Erase cells</button>
  </aside>
</section>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const circles1 = document.querySelectorAll(".c");
    const circles2 = document.querySelectorAll(".c2");
    const circles3 = document.querySelectorAll(".c3");
    const circles4 = document.querySelectorAll(".c4");

    const r1 = document.getElementById("r");
    const l = document.getElementById("l");
    const r2 = document.getElementById("r2");
    const l2 = document.getElementById("l2");
    const r3 = document.getElementById("r3");
    const l3 = document.getElementById("l3");
    const r4 = document.getElementById("r4");
    const l4 = document.getElementById("l4");

    const w1 = document.getElementById("w1");
    const w2 = document.getElementById("w2");
    const w3 = document.getElementById("w3");
    const w4 = document.getElementById("w4");

    const d1 = document.getElementById("d1");
    const d2 = document.getElementById("d2");
    const d3 = document.getElementById("d3");
    const d4 = document.getElementById("d4");
    const d5 = document.getElementById("d5");
    const d6 = document.getElementById("d6");
    const erase = document.getElementById("erase");

    let state1 = 7;
    let state2 = 7;
    let state3 = 7;
    let state4 = 7;

    function bits(value) {
      return value.toString(2).padStart(3, "0");
    }

    function updateDisplay() {
      const total = bits(state1) + bits(state2) + bits(state3) + bits(state4);
      d1.textContent = bits(state1);
      d2.textContent = bits(state2);
      d3.textContent = bits(state3);
      d4.textContent = bits(state4);
      d5.textContent = total;
      d6.textContent = parseInt(total, 2).toString(16).toUpperCase();
    }

    updateDisplay();

    erase.addEventListener("click", () => {
      state1 = 7;
      state2 = 7;
      state3 = 7;
      state4 = 7;

      circles1.forEach((circle) => l.appendChild(circle));
      circles2.forEach((circle) => l2.appendChild(circle));
      circles3.forEach((circle) => l3.appendChild(circle));
      circles4.forEach((circle) => l4.appendChild(circle));
      updateDisplay();
    });

    w1.addEventListener("click", () => {
      if (state1 > 0) {
        r1.appendChild(circles1[state1 - 1]);
        state1--;
        updateDisplay();
      }
    });

    w2.addEventListener("click", () => {
      if (state2 > 0) {
        r2.appendChild(circles2[state2 - 1]);
        state2--;
        updateDisplay();
      }
    });

    w3.addEventListener("click", () => {
      if (state3 > 0) {
        r3.appendChild(circles3[state3 - 1]);
        state3--;
        updateDisplay();
      }
    });

    w4.addEventListener("click", () => {
      if (state4 > 0) {
        r4.appendChild(circles4[state4 - 1]);
        state4--;
        updateDisplay();
      }
    });
  });
</script>