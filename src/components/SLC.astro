---
// SLC.astro
import "../styles/interactables.css";

const charges1 = Array.from({ length: 1 });
const NUM_CELLS = 8;

const cells = Array.from({ length: NUM_CELLS }, (_, i) => {
  const index = i + 1;

  return {
    gate: `w1${index}`,
    store: index === 1 ? "r1" : `r1${index}`,
    bank: index === 1 ? "l1" : `l1${index}`,
    display: `d1${index}`,
    label:
      index === 1
      ? `Cell ${index} (MS)`
      : index === NUM_CELLS
      ? `Cell ${index} (LS)`
      : `Cell ${index}`,
    chargeClass: index === 1 ? "c_" : `c_${index}`,
  };
});
---

<section class="flash-demo flash-demo--slc" aria-label="Single-Level Cell demo">
  <div class="flash-demo__cells">
    {cells.map((cell) => (
      <div class="shrink">
        <button id={cell.gate} class="flash-demo__layer flash-demo__gate" type="button" data-tooltip="A voltage is applied to the control gate allowing it to write/read/erase the contents of a cell. \n Clicking this adds a charge to the floating gate.">{cell.label}'s control gate</button>
        <div class="flash-demo__layer flash-demo__oxide" data-tooltip="The insulator prevents electrons from escaping.">Insulator</div>
        <div class="flash-demo__layer flash-demo__floating" data-tooltip="This is where the charge is stored and it determines the value of a cell.\n The amount of charge also affects the cells conductivity.">
          Floating Gate
          <div id={cell.store} class="flash-demo__charge-well"></div>
        </div>
        <div class="flash-demo__layer flash-demo__oxide" data-tooltip="The insulator prevents electrons from escaping.">Insulator</div>
        <div class="flash-demo__layer flash-demo__substrate" data-tooltip="The substrate is a medium for voltage to pass through that allows for read/write operations.">
          <div class="substrate_box" id="source" data-tooltip="This is where electrons come from when entering a cell.">source</div>
          Substrate
          <div class="substrate_box" id="drain" data-tooltip="This is where electrons go to after an erase/write.">drain</div>
          <div id={cell.bank} class="flash-demo__charge-bank" data-tooltip="Represents the electrons that came from the source.">
            {charges1.map((_, i) => (
              <div class={`flash-demo__charge flash-demo__charge--slc ${cell.chargeClass}`} data-id={i}></div>
            ))}
          </div>
        </div>
      </div>

    ))}
    <div class="bitline" data-tooltip="During read operations, the bitline applies a charge that can sense a cells value depending on it's conductivity.\n During write operations, the bitline delivers the charge that changes a cell's value.">Bit Line 1</div>
    <div id="bitline2" class="bitline" data-tooltip="During read operations, the bitline applies a charge that can sense a cells value depending on it's conductivity.\n During write operations, the bitline delivers the charge that changes a cell's value.">Bit Line 1</div>
  </div>

  <aside class="flash-demo__panel">
    <p>Click a control gate to program one SLC cell.</p>
    <p>Each SLC cell represents 1 bit, so each cell only needs two possible states: 1 or 0.</p>

    <div class="flash-demo__display" aria-label="Current SLC stored values">
      {cells.map((cell) => (
        <div class="flash-demo__value">
          <span>{cell.label.replace("Control Gate ", "")}</span>
          <strong id={cell.display}></strong>
        </div>
      ))}
      <div class="flash-demo__value flash-demo__value--wide">
        <span>Total bits</span>
        <strong id="totalBits_1"></strong>
      </div>
      <div class="flash-demo__value">
        <span>Hex</span>
        <strong id="hexValue_1"></strong>
      </div>
    </div>

    <button class="flash-demo__erase" id="erase1" type="button">Erase cells</button>
  </aside>
</section>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const NUM_CELLS = 8; //Keep the same as the one ontop!

    const erase1 = document.getElementById("erase1");

    const cellElements = document.querySelectorAll(".flash-demo__cell");

    const cells = Array.from({ length: NUM_CELLS }, (_, i) => {
      const index = i + 1;

      return {
        circles: document.querySelectorAll(`.c_${index === 1 ? "" : index}`),
        r1: document.getElementById(index === 1 ? "r1" : `r1${index}`),
        l1: document.getElementById(index === 1 ? "l1" : `l1${index}`),
        w1: document.getElementById(`w1${index}`),
        d1: document.getElementById(`d1${index}`),
        state: 1,
      };
    });

    const totalBits = document.getElementById("totalBits_1");
    const hexValue = document.getElementById("hexValue_1");

    function bits(value) {
      return value.toString(2)
    }

    function updateDisplay() {
      let total = "";

      cells.forEach((cell) => {
        const b1 = bits(cell.state);
        cell.d1.textContent = b1;
        total += b1;
      });

      totalBits.textContent = total;
      hexValue.textContent = parseInt(total, 2).toString(16).toUpperCase();
    }

    updateDisplay();

    erase1.addEventListener("click", () => {
      cells.forEach((cell) => {
        cell.state = 1;
        cell.circles.forEach((circle) => cell.l1.appendChild(circle));
      });
      updateDisplay();
    });

    cells.forEach((cell) => {
      cell.w1.addEventListener("click", () => {
        if (cell.state > 0) {
          cell.r1.appendChild(cell.circles[cell.state - 1]);
          cell.state--;
          updateDisplay();
        }
      });
    });
  });
</script>