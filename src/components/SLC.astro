---
// SLC.astro
import "../styles/interactables.css";

const charges = Array.from({ length: 1 });
const cells = [
  { gate: "w1_s", store: "r_s", bank: "l_s", display: "d1_s", label: "Cell 1 (MS)", chargeClass: "c_s" },
  { gate: "w2_s", store: "r2_s", bank: "l2_s", display: "d2_s", label: "Cell 2 ", chargeClass: "c2_s" },
  { gate: "w3_s", store: "r3_s", bank: "l3_s", display: "d3_s", label: "Cell 3 ", chargeClass: "c3_s" },
  { gate: "w4_s", store: "r4_s", bank: "l4_s", display: "d4_s", label: "Cell 4 (LS)", chargeClass: "c4_s" },
];
---

<section class="flash-demo flash-demo--slc" aria-label="Single-Level Cell demo">
  <div class="flash-demo__cells">
    {cells.map((cell) => (
      <article class="flash-demo__cell">
        <button id={cell.gate} class="flash-demo__layer flash-demo__gate" type="button">{cell.label}</button>
        <div class="flash-demo__layer flash-demo__oxide">Isolation Layer</div>
        <div class="flash-demo__layer flash-demo__floating">
          Floating Gate
          <div id={cell.store} class="flash-demo__charge-well"></div>
        </div>
        <div class="flash-demo__layer flash-demo__oxide">Isolation Layer</div>
        <div class="flash-demo__layer flash-demo__substrate">
          Substrate
          <div id={cell.bank} class="flash-demo__charge-bank">
            {charges.map((_, i) => (
              <div class={`flash-demo__charge flash-demo__charge--slc ${cell.chargeClass}`} data-id={i}></div>
            ))}
          </div>
        </div>
      </article>
    ))}
  </div>

  <aside class="flash-demo__panel">
    <p>Click a control gate to program one SLC cell.</p>
    <p>Each SLC cell represents 1 bit, so each cell only needs two possible states: 1 or 0.</p>

    <div class="flash-demo__display" aria-label="Current SLC stored values">
      {cells.map((cell) => (
        <div class="flash-demo__value">
          <span>{cell.label.replace("Control Gate ", "")}</span>
          <strong id={cell.display}></strong>
        </div>
      ))}
      <div class="flash-demo__value flash-demo__value--wide">
        <span>Total bits</span>
        <strong id="d5_s"></strong>
      </div>
      <div class="flash-demo__value">
        <span>Hex</span>
        <strong id="d6_s"></strong>
      </div>
    </div>

    <button class="flash-demo__erase" id="erase_s" type="button">Erase cells</button>
  </aside>
</section>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const circles1 = document.querySelectorAll(".c_s");
    const circles2 = document.querySelectorAll(".c2_s");
    const circles3 = document.querySelectorAll(".c3_s");
    const circles4 = document.querySelectorAll(".c4_s");

    const r1 = document.getElementById("r_s");
    const l1 = document.getElementById("l_s");
    const r2 = document.getElementById("r2_s");
    const l2 = document.getElementById("l2_s");
    const r3 = document.getElementById("r3_s");
    const l3 = document.getElementById("l3_s");
    const r4 = document.getElementById("r4_s");
    const l4 = document.getElementById("l4_s");

    const w1 = document.getElementById("w1_s");
    const w2 = document.getElementById("w2_s");
    const w3 = document.getElementById("w3_s");
    const w4 = document.getElementById("w4_s");

    const d1 = document.getElementById("d1_s");
    const d2 = document.getElementById("d2_s");
    const d3 = document.getElementById("d3_s");
    const d4 = document.getElementById("d4_s");
    const d5 = document.getElementById("d5_s");
    const d6 = document.getElementById("d6_s");
    const erase = document.getElementById("erase_s");

    let state1 = 1;
    let state2 = 1;
    let state3 = 1;
    let state4 = 1;

    function updateDisplay() {
      const total = `${state1}${state2}${state3}${state4}`;
      d1.textContent = state1.toString(2);
      d2.textContent = state2.toString(2);
      d3.textContent = state3.toString(2);
      d4.textContent = state4.toString(2);
      d5.textContent = total;
      d6.textContent = parseInt(total, 2).toString(16).toUpperCase();
    }

    updateDisplay();

    erase.addEventListener("click", () => {
      state1 = 1;
      state2 = 1;
      state3 = 1;
      state4 = 1;

      circles1.forEach((charge) => l1.appendChild(charge));
      circles2.forEach((charge) => l2.appendChild(charge));
      circles3.forEach((charge) => l3.appendChild(charge));
      circles4.forEach((charge) => l4.appendChild(charge));
      updateDisplay();
    });

    w1.addEventListener("click", () => {
      if (state1 > 0) {
        r1.appendChild(circles1[state1 - 1]);
        state1--;
        updateDisplay();
      }
    });

    w2.addEventListener("click", () => {
      if (state2 > 0) {
        r2.appendChild(circles2[state2 - 1]);
        state2--;
        updateDisplay();
      }
    });

    w3.addEventListener("click", () => {
      if (state3 > 0) {
        r3.appendChild(circles3[state3 - 1]);
        state3--;
        updateDisplay();
      }
    });

    w4.addEventListener("click", () => {
      if (state4 > 0) {
        r4.appendChild(circles4[state4 - 1]);
        state4--;
        updateDisplay();
      }
    });
  });
</script>