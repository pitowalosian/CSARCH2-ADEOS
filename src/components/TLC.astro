---
// TLC.astro
import "../styles/interactables.css";

const charges = Array.from({ length: 7 });
const NUM_CELLS = 8;

const cells = Array.from({ length: NUM_CELLS }, (_, i) => {
  const index = i + 1;

  return {
    gate: `w${index}`,
    store: index === 1 ? "r" : `r${index}`,
    bank: index === 1 ? "l" : `l${index}`,
    display: `d${index}`,
    label:
      index === 1
      ? `Cell ${index} (MS)`
      : index === NUM_CELLS
      ? `Cell ${index} (LS)`
      : `Cell ${index}`,
    chargeClass: index === 1 ? "c" : `c${index}`,
  };
});
---

<section class="flash-demo flash-demo--tlc" aria-label="Triple-Level Cell demo">
  <div class="flash-demo__cells">
    {cells.map((cell) => (
      <div class="shrink">
        <button id={cell.gate} class="flash-demo__layer flash-demo__gate" type="button" data-tooltip="A voltage is applied to the control gate allowing it to write/read/erase the contents of a cell. \n Clicking this adds a charge to the floating gate.">{cell.label}'s control gate</button>
        <div class="flash-demo__layer flash-demo__oxide" data-tooltip="The insulator prevents electrons from escaping.">Insulator Layer</div>
        <div class="flash-demo__layer flash-demo__floating" data-tooltip="This is where the charge is stored and it determines the value of a cell.\n The amount of charge also affects the cells conductivity.">
          Floating Gate
          <div id={cell.store} class="flash-demo__charge-well"></div>
        </div>
        <div class="flash-demo__layer flash-demo__oxide" data-tooltip="The insulator prevents electrons from escaping.">Insulator Layer</div>
        <div class="flash-demo__layer flash-demo__substrate" data-tooltip="The substrate is a medium for voltage to pass through that allows for read/write operations.">
          <div class="substrate_box" id="source" data-tooltip="This is where electrons come from when entering a cell.">source</div>
          Substrate
          <div class="substrate_box" id="drain" data-tooltip="This is where electrons go to after an erase/write.">drain</div>
          <div id={cell.bank} class="flash-demo__charge-bank" data-tooltip="Represents the electrons that came from the source.">
            {charges.map((_, i) => (
              <div class={`flash-demo__charge flash-demo__charge--tlc ${cell.chargeClass}`} data-id={i}></div>
            ))}
          </div>
        </div>
      </div>
    ))}
    <div class="bitline" data-tooltip="During read operations, the bitline applies a charge that can sense a cells value depending on it's conductivity.\n During write operations, the bitline delivers the charge that changes a cell's value.">Bit Line 2</div>
    <div id="bitline2" class="bitline" data-tooltip="During read operations, the bitline applies a charge that can sense a cells value depending on it's conductivity.\n During write operations, the bitline delivers the charge that changes a cell's value.">Bit Line 2</div>
  </div>

  <aside class="flash-demo__panel">
    <p>Click a control gate to move one charge marker into the floating gate.</p>
    <p>Each TLC cell represents 3 bits, so each cell can step through eight possible states.</p>

    <div class="flash-demo__display" aria-label="Current TLC stored values">
      {cells.map((cell) => (
        <div class="flash-demo__value">
          <span>{cell.label.replace("Control Gate ", "")}</span>
          <strong id={cell.display}></strong>
        </div>
      ))}
      <div class="flash-demo__value flash-demo__value--wide">
        <span>Total bits</span>
        <strong id="totalBits"></strong>
      </div>
      <div class="flash-demo__value">
        <span>Hex</span>
        <strong id="hexValue"></strong>
      </div>
    </div>

    <button class="flash-demo__erase" id="erase" type="button" data-tooltip="A cell must be erased before it can be written on.\n This button brings cells back to its highest state.">Erase cells</button>

    <div id="tooltip"></div>
  </aside>
</section>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const NUM_CELLS = 8; //Keep the same as the one ontop!

    const erase = document.getElementById("erase");

    const cells = Array.from({ length: NUM_CELLS }, (_, i) => {
      const index = i + 1;

      return {
        circles: document.querySelectorAll(`.c${index === 1 ? "" : index}`),
        r: document.getElementById(index === 1 ? "r" : `r${index}`),
        l: document.getElementById(index === 1 ? "l" : `l${index}`),
        w: document.getElementById(`w${index}`),
        d: document.getElementById(`d${index}`),
        state: 7,
      };
    });

    const totalBits = document.getElementById("totalBits");
    const hexValue = document.getElementById("hexValue");

    const tooltip = document.getElementById('tooltip');
    const boxes = document.querySelectorAll('[data-tooltip]');

    function bits(value) {
      return value.toString(2).padStart(3, "0");
    }

    function updateDisplay() {
      let total = "";

      cells.forEach((cell) => {
        const b = bits(cell.state);
        cell.d.textContent = b;
        total += b;
      });

      totalBits.textContent = total;
      hexValue.textContent = parseInt(total, 2).toString(16).toUpperCase();
    }

    updateDisplay();

    erase.addEventListener("click", () => {
      cells.forEach((cell) => {
        cell.state = 7;
        cell.circles.forEach((circle) => cell.l.appendChild(circle));
      });
      updateDisplay();
    });

    cells.forEach((cell) => {
      cell.w.addEventListener("click", () => {
        if (cell.state > 0) {
          cell.r.appendChild(cell.circles[cell.state - 1]);
          cell.state--;
          updateDisplay();
        }
      });
    });


    //tooltip
    boxes.forEach(box => {
    box.addEventListener('mouseenter', () => {
      tooltip.textContent = box.dataset.tooltip;
      tooltip.classList.add('visible');
    });
 
    box.addEventListener('mousemove', (e) => {
      const offsetX = 15;
      const offsetY = 15;
      tooltip.style.transform = `translate(${e.clientX + offsetX}px, ${e.clientY + offsetY}px)`;
    });
 
    box.addEventListener('mouseleave', () => {
      tooltip.classList.remove('visible');
    });

  });
});
</script>